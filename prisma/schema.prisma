generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id          String   @id @default(cuid())
  fullName    String
  title       String
  location    String?
  bio         String            // Extracto corto → Hero card
  aboutMe     String?           // Biografía completa → Biography section
  avatarUrl   String?
  socialLinks SocialLink[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SocialLink {
  id        String   @id @default(cuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  label     String
  url       String?
  iconUrl   String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Experience {
  id          String    @id @default(cuid())
  company     String
  position    String
  startDate   DateTime
  endDate     DateTime?
  description String
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Education {
  id           String    @id @default(cuid())
  institution  String
  degree       String
  fieldOfStudy String?
  startDate    DateTime
  endDate      DateTime?
  description  String?
  order        Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model SkillCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  order     Int      @default(0)
  skills    Skill[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Skill {
  id         String   @id @default(cuid())
  name       String
  categoryId String
  category   SkillCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  level      Int      @default(80)
  iconUrl    String?
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Project {
  id           String    @id @default(cuid())
  title        String
  description  String
  technologies String
  imageUrl     String?
  projectUrl   String?
  githubUrl    String?
  startDate    DateTime?
  endDate      DateTime?
  featured     Boolean   @default(false)
  order        Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Certification {
  id        String   @id @default(cuid())
  title     String
  issuer    String
  date      DateTime
  url       String?
  fileUrl   String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model VisitorLog {
  id         String   @id @default(cuid())
  ipAddress  String   @default("Desconocida")
  city       String?
  country    String?
  deviceType String?
  os         String?
  userAgent  String?
  visitCount Int      @default(1)
  lastVisit  DateTime @default(now())
  createdAt  DateTime @default(now())
}

model SoftSkill {
  id        String   @id @default(cuid())
  name      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
